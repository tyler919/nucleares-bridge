# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# A long random secret shared with Home Assistant.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
HA_API_KEY=replace-with-a-long-random-secret

# IP address of your Home Assistant server.
# Only requests from this IP will be accepted.
# Leave blank to allow any IP on your LAN (less secure).
ALLOWED_IP=192.168.1.50

# Port the bridge listens on. Must be reachable from your HA server.
BRIDGE_PORT=8765

# How often (seconds) to poll the Nucleares webserver.
POLL_INTERVAL=5

# Nucleares webserver address. Only change if the game uses a different port.
NUCLEARES_URL=http://localhost:8080/

# Log file path (relative to bridge.py directory).
LOG_FILE=bridge.log

# Minimum log level written to file and shown in UI. DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
